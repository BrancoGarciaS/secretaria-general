document.addEventListener('DOMContentLoaded',function(){var divAccesibilidad=document.querySelector('.region-accesibilidad');if(divAccesibilidad){divAccesibilidad.classList.add('collapse');divAccesibilidad.id='collapseAcc';}var buttons=document.querySelectorAll(".accordion-button");buttons.forEach(function(button){button.addEventListener("click",function(){var collapseArea=button.closest(".collapse");if(collapseArea)collapseArea.classList.remove("show");});});var lineBreaks=document.querySelectorAll('br');lineBreaks.forEach(function(br){var newLineBreak=document.createElement('br');br.parentNode.insertBefore(newLineBreak,br.nextSibling);});var elementos=document.querySelectorAll('.region-menu-universidad');elementos.forEach(function(elemento){elemento.classList.add('row');});var brandingDiv=document.getElementById('block-usach-branding');if(brandingDiv)brandingDiv.classList.add('col-4','col-md-5');var searchFormDiv=document.getElementById('block-usach-search-form');if(searchFormDiv)searchFormDiv.classList.add('col-8','col-md-7');var navegacionDiv=document.getElementById('block-usach-navegacionprincipal-3');if(navegacionDiv)navegacionDiv.classList.add('col-12','col-md-8');var iconosDiv=document.getElementById('block-usach-iconosheader');if(iconosDiv)iconosDiv.classList.add('col-8','col-md-3');var menuDiv=document.getElementById('block-usach-menuareascollapse');if(menuDiv)menuDiv.classList.add('col-0','col-md-8');var menuDiv3=document.getElementById('block-usach-menuareascollapseen');if(menuDiv3)menuDiv3.classList.add('col-0','col-md-8');var menuDiv2=document.getElementById('block-usach-menuareascollapsept');if(menuDiv2)menuDiv2.classList.add('col-0','col-md-8');var idiomaDiv=document.getElementById('block-usach-idioma');if(idiomaDiv)idiomaDiv.classList.add('col-0','col-md-1');var idiomaDiv2=document.getElementById('block-usach-alternadordeidioma');if(idiomaDiv2)idiomaDiv2.classList.add('col-0','col-md-1');var idiomaDiv3=document.getElementById('block-usach-alternadordeidioma-2');if(idiomaDiv3)idiomaDiv3.classList.add('col-0','col-md-1');var alternadoresDeIdioma=[document.getElementById('block-usach-alternadordeidioma'),document.getElementById('block-usach-alternadordeidioma-2')];alternadoresDeIdioma.forEach(function(alternadorDeIdioma,index){if(alternadorDeIdioma){var listasUl=alternadorDeIdioma.querySelectorAll("ul");alternadorDeIdioma.classList.add("dropdown");alternadorDeIdioma.classList.add("show");listasUl.forEach(function(ul){ul.classList.add("dropdown-menu");ul.setAttribute("aria-labelledby","dropdownMenuLink"+index);ul.setAttribute("data-block","idioma");var itemsLi=ul.querySelectorAll("li");itemsLi.forEach(function(li){li.classList.add("dropdown-item");});});var h2Elements=alternadorDeIdioma.querySelectorAll("h2");h2Elements.forEach(function(h2){h2.classList.add("dropdown-toggle");h2.setAttribute("href","#");h2.setAttribute("role","button");h2.setAttribute("id","dropdownMenuLink"+index);h2.setAttribute("data-bs-toggle","dropdown");h2.setAttribute("aria-haspopup","true");h2.setAttribute("aria-expanded","false");h2.setAttribute("tabindex","-1");});}});var element=document.querySelector('.region-nav-additional');if(element)element.classList.add('d-flex');var textos=document.querySelectorAll(".texto1, .texto2, .texto3");textos.forEach(function(texto){texto.classList.add("col-md-4");texto.classList.add("col-12");});var centros=document.querySelectorAll(".centro");centros.forEach(function(centro){centro.classList.add("row");});var contenedores=document.querySelectorAll(".contenedor");contenedores.forEach(function(contenedor){contenedor.classList.add("container");});var dropdownToggles=document.querySelectorAll("span.dropdown-toggle");dropdownToggles.forEach(function(toggle){toggle.addEventListener("click",function(){var dropdownMenus=toggle.querySelectorAll("ul.dropdown-menu");dropdownMenus.forEach(function(menu){menu.classList.toggle("show");});});});const liElements=document.querySelectorAll('.block-language-blocklanguage-interface li');liElements.forEach((li,index)=>{li.id=`li-${index+1}`;});$(document).ready(function(){$(".region-nav-main .dropdown-toggle").hover(function(){$(this).attr("tooltip-data",$(this).attr("title"));$(this).removeAttr("title");},function(){$(this).attr("title",$(this).attr("tooltip-data"));$(this).removeAttr("tooltip-data");});});});;
(function($,Drupal,window,document,undefined){Drupal.behaviors.myBehavior={attach:function(context,settings){$('#test',context).on('click',function(){alert('Hola');});}};})(jQuery,Drupal,window,document);;
